STRAVA_API_CLIENT_ID=<strava api client id>
STRAVA_API_CLIENT_SECRET=<strava api client secret>
STRAVA_API_REFRESH_TOKEN=<strava api refresh token>

# Redis: use password-protected URL in production (e.g. redis://:password@host:6379)
REDIS_URL=redis://redis:6379
# Optional: TTL in seconds for credentials stored in Redis (empty = no expiry)
REDIS_CREDENTIALS_TTL=

# Activities cache: TTL in seconds (default 86400 = 24 hours). Set to 0 or leave empty to use default.
STRAVA_ACTIVITIES_CACHE_TTL_SECONDS=
# Set to false, 0, or no to disable activities cache
STRAVA_ACTIVITIES_CACHE_ENABLED=true

# Required in production. Set FLASK_DEBUG=true only for local development.
FLASK_SECRET_KEY=<required in production; use a strong random value>
FLASK_DEBUG=false

# Set to true when serving over HTTPS (secures session cookies)
PREFER_HTTPS=false

# Optional: if set, users must enter this password to save or clear Strava credentials on /config
CONFIG_EDIT_PASSWORD=

# Optional: Flask server port (default: 5000)
FLASK_PORT=5000

# Rate limiting: optional Redis URI for limit storage (e.g. redis://:password@host:6379/1). If unset, uses in-memory.
RATE_LIMIT_STORAGE_URI=
# Default limit applied to all routes (e.g. "200 per hour")
RATE_LIMIT_DEFAULT=200 per hour
# Limit for /config (e.g. "10 per minute")
RATE_LIMIT_CONFIG=10 per minute
# Limit for /activity-list, /dashboard, /lab (e.g. "30 per minute")
RATE_LIMIT_API=30 per minute
